{
  "expo": {
    "name": "The Dabba",
    "slug": "the-dabba",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "thedabba",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thedabba.app",
      "buildNumber": "16",
      "newArchEnabled": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "UIRequiredDeviceCapabilities": [
          "armv7"
        ],
        "GCSupportsGameCenterDashboard": false,
        "NSCameraUsageDescription": "Take delivery proof photos",
        "NSPhotoLibraryUsageDescription": "Select photos for your profile",
        "NSLocationWhenInUseUsageDescription": "Find nearest deliveries to optimize your route",
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#8B1538"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.thedabba.app",
      "versionCode": 16,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FDF8F3"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow The Dabba to use your location to find nearest deliveries."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow The Dabba to access your photos.",
          "cameraPermission": "Allow The Dabba to take delivery proof photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "3476b33a-d63b-4572-a172-fa3415e8bffb"
      },
      "apiUrl": "https://delivery-test-2.preview.emergentagent.com/api"
    },
    "owner": "thedabba"
  }
}
